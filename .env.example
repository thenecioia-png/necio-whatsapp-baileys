# ═══════════════════════════════════════════════════════════════════
# Necio WhatsApp Bot v3.0 - Multi-IA · Fallback Infinito · 24/7
# ═══════════════════════════════════════════════════════════════════

# ─── Servidor ───────────────────────────────────────────────────
PORT=3002
HOST=0.0.0.0

# ─── Seguridad ──────────────────────────────────────────────────
# API Secret para proteger endpoints HTTP (/send, /human-mode)
# Si no se configura, los endpoints quedan abiertos
API_SECRET=tu_clave_secreta_aqui

# ─── IA PROVIDERS (configura TODAS las que puedas para máxima robustez) ──

# 1. GROQ (rápido, bueno para diario)
# https://console.groq.com/keys → gratis, 100k tokens/día
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# 2. GOOGLE GEMINI (gratis generoso)
# https://aistudio.google.com/app/apikey → gratis, 60 req/min
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# 3. OPENROUTER (acceso a docenas de modelos, algunos gratis)
# https://openrouter.ai/keys → gratis con modelos :free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# 4. MISTRAL AI (freemium)
# https://console.mistral.ai/api-keys → gratis limitado
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-tiny

# ═══════════════════════════════════════════════════════════════════
# NUEVAS APIs GRATUITAS (ILIMITADO)
# ═══════════════════════════════════════════════════════════════════

# 5. CEREBRAS → 1.5M tokens/día GRATIS, 30 req/min
# https://cloud.cerebras.ai/platform → Sign up, Get API Key
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.1-8b

# 6. TOGETHER AI → 1M tokens/mes GRATIS
# https://api.together.xyz/settings/api-keys → Sign up, Create Key
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.1-8B-Instruct-Turbo

# 7. GITHUB MODELS → 50 chat completions/mes GRATIS
# https://github.com/settings/tokens → Settings → Developer settings → Personal access tokens
# Necesita scope: models_read
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=meta-llama-3.1-8b-instruct

# ─── n8n Webhook (opcional) ─────────────────────────────────────
N8N_WEBHOOK_URL=

# ─── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_SECONDS=10

# ─── Memoria ────────────────────────────────────────────────────
MEMORY_MAX_MESSAGES=5
PERSIST_MEMORY=true

# ─── Comandos ───────────────────────────────────────────────────
HUMAN_COMMAND=/humano

# ─── Admin ──────────────────────────────────────────────────────
ADMIN_WHATSAPP=18297837862

# ─── Producción ─────────────────────────────────────────────────
NODE_ENV=production

# ─── Tuning ─────────────────────────────────────────────────────
MAX_MESSAGE_LENGTH=1000
CLEANUP_INTERVAL_MS=3600000
RETRY_SEND_MAX=2
AI_TIMEOUT_MS=15000
CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_RESET_MS=300000

# ═══════════════════════════════════════════════════════════════════
# ANTI-BAN (Protección contra bloqueos de WhatsApp)
# ═══════════════════════════════════════════════════════════════════

# Activar/desactivar protección anti-ban (default: true)
ANTI_BAN_ENABLED=true

# Flood protection: max mensajes por ventana de tiempo
FLOOD_MAX_MESSAGES=5
FLOOD_WINDOW_SECONDS=60
FLOOD_COOLDOWN_SECONDS=300

# Spam detection: veces que un usuario puede repetir el mismo mensaje
SPAM_SIMILARITY_THRESHOLD=3

# Typing simulation: delays humanizados (ms)
TYPING_DELAY_MIN_MS=800
TYPING_DELAY_MAX_MS=2500
TYPING_SPEED_WPM=80

# Session rotation: rotar sesión automáticamente tras múltiples fallos 401
SESSION_ROTATION_ENABLED=true

# ═══════════════════════════════════════════════════════════════════
# SUPABASE (PostgreSQL en la nube, gratis 500MB)
# ═══════════════════════════════════════════════════════════════════
SUPABASE_URL=https://0dd4bead775ec386792684ce97624741.supabase.co
SUPABASE_KEY=sbp_tu_service_role_key_aqui

# ─── Base de datos local (alternativa a Supabase) ───────────────
# DATABASE_URL=postgresql://necio:necio2026@localhost:5432/necio
# REDIS_URL=redis://localhost:6379/0
